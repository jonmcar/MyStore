# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
Thumbs.db
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (NEVER commit — contains DB password and other secrets)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# prisma generated client (regenerated by `npx prisma generate`)
/src/generated/prisma

# uploaded images — served at runtime, never source data
/public/uploads/*
!/public/uploads/.gitkeep

# frozen seed snapshots can get huge — gitignore by default.
# if you have a small, canonical one worth committing, add a
# negation line like `!/prisma/seeds/frozen-canonical.ts`
/prisma/seeds/private/*
!/prisma/seeds/private/.gitkeep

# editor / IDE junk
.vscode/
.idea/
*.swp
*.swo
*~